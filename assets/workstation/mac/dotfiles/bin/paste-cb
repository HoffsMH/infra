#!/bin/bash
# Paste from system clipboard - handles both images and files

TARGET_DIR="${1:-.}"

# Check if clipboard contains image data
if osascript -e 'clipboard info' 2>/dev/null | grep -q 'PNGf\|JPEG\|TIFF'; then
    # Extract image from clipboard and save as PNG
    timestamp=$(date +%Y-%m-%d-%H%M%S)
    filename="screenshot-${timestamp}.png"
    filepath="${TARGET_DIR}/${filename}"

    # Use osascript to extract PNG data from clipboard
    osascript -e "
        set theFile to POSIX file \"$filepath\"
        try
            set imageData to the clipboard as «class PNGf»
            set fileRef to open for access theFile with write permission
            set eof fileRef to 0
            write imageData to fileRef
            close access fileRef
            return \"success\"
        on error errMsg
            try
                close access theFile
            end try
            error errMsg
        end try
    " >/dev/null 2>&1

    if [ $? -eq 0 ]; then
        echo "Saved screenshot as $filename"
        exit 0
    else
        echo "Failed to save screenshot"
        exit 1
    fi
else
    # Try pasting files with cb
    cd "$TARGET_DIR" && cb paste
    exit $?
fi
