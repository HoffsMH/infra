# The syntax is "key = value". The whitespace around the
# equals doesn't matter.
# background = ffffff
# foreground = ffffff

# Comments start with a `#` and are only valid on their own line.
# Blank lines are ignored!

# keybind = unconsumed:cmd+f=ignore
# keybind = unconsumed:cmd+f=esc:\x1b
#
keybind = all:unconsumed:cmd+f=text:\x1bf

keybind = global:unconsumed:cmd+a=reload_config 

keybind = cmd+d=text:\x1bd
keybind = cmd+u=text:\x1bu
keybind = cmd+enter=text:\x1b\r
keybind = cmd+y=text:\x1by
keybind = cmd+e=text:\x1be

keybind = global:cmd+grave_accent=toggle_quick_terminal

# Empty values reset the configuration to the default value
font-family =
theme = Gruvbox Dark
