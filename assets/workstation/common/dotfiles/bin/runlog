#!/bin/zsh -i

# Run a command and log output to ../<current-dir>-<root-command>.log
# Usage: runlog <command> [args...]
# Example: runlog rspec spec/models/user_spec.rb
#   → runs the command and logs to ../anvyl-core-api-rspec.log

if [ $# -eq 0 ]; then
    echo "Usage: runlog <command> [args...]"
    exit 1
fi

dirn=$(basename "$PWD")

# Skip wrapper commands to find the meaningful command name
skip=(bundle exec npx npm yarn env nice nohup time sudo)
rootcmd=""
for arg in "$@"; do
    if (( ! ${skip[(Ie)$(basename "$arg")]} )); then
        rootcmd=$(basename "$arg")
        break
    fi
done
rootcmd=${rootcmd:-$(basename "$1")}

logfile="$(dirname "$PWD")/${dirn}-${rootcmd}.log"

echo "Logging to: $logfile"
eval "$@" > "$logfile" 2>&1
exit_code=$?

if [ $exit_code -ne 0 ]; then
    echo "Command exited with status $exit_code"
fi

echo "Output saved to: $logfile"
exit $exit_code
