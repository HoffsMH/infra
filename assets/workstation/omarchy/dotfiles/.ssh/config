# SSH config for this Omarchy host.
# Source of truth in ~/infra/assets/workstation/omarchy/dotfiles/.ssh/config
# Symlinked to ~/.ssh/config by setup-yubikey.sh.
#
# Per-machine overrides (work account keys, throwaway hosts) go in
# ~/.ssh/config.local -- NOT in infra, gitignored.

# Per-machine include first so its specific Host entries match before the
# wildcards below.
Include ~/.ssh/config.local

# Personal GitHub via the YubiKey-resident GPG AUT subkey, presented over
# $SSH_AUTH_SOCK by gpg-agent. With `IdentitiesOnly yes`, SSH filters the
# agent's keys against IdentityFile pubkeys -- so we explicitly point at
# a dumped copy of the YubiKey AUT pubkey. Without this, SSH only tries
# the default ~/.ssh/id_{rsa,ecdsa,ed25519,...} names (which don't exist)
# and ignores the YubiKey entirely.
Host github.com
  User git
  IdentityFile ~/.ssh/id_yubikey_auth.pub
  IdentitiesOnly yes
  AddKeysToAgent yes

# Defaults for everything else.
Host *
  AddKeysToAgent yes
  ServerAliveInterval 60
  ServerAliveCountMax 3
